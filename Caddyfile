pierrekasparian.com, www.pierrekasparian.com {
	encode zstd gzip

	@www host www.pierrekasparian.com
	redir @www https://pierrekasparian.com{uri} permanent

	reverse_proxy app:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		X-Frame-Options           "SAMEORIGIN"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
		-Server

		Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
	}
}
